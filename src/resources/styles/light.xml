<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="light"
              name="Light"
              version="1.0">

  <!-- fondo general -->
  <style name="text"
         foreground="#000000"
         background="#ffffff"/>

  <!-- numeros de linea -->
  <style name="line-numbers"
         foreground="#555555"
         background="#f0f0f0"/>

  <!-- palabras reservadas -->
  <style name="def:keyword"
         foreground="#0000ff"
         bold="true"/>

  <!-- identificadores -->
  <style name="def:identifier"
         foreground="#000000"/>

  <!-- numeros -->
  <style name="def:number"
         foreground="#098658"/>

  <!-- comentarios -->
  <style name="def:comment"
         foreground="#008000"
         italic="true"/>

  <!-- operadores -->
  <style name="def:operator"
         foreground="#000000"/>

  <!-- statements / logicos -->
  <style name="def:statement"
         foreground="#0000ff"/>

  <!-- simbolos -->
  <style name="def:special-char"
         foreground="#a31515"/>

  <!-- strings -->
  <style name="def:string"
         foreground="#a31515"/>

</style-scheme>
