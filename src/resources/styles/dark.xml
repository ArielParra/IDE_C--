<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="dark"
              name="Dark"
              version="1.0">

  <!-- fondo general -->
  <style name="text"
         foreground="#ffffff"
         background="#1e1e1e"/>

  <!-- palabras reservadas -->
  <style name="def:keyword"
         foreground="#569cd6"
         bold="true"/>

  <!-- identificadores -->
  <style name="def:identifier"
         foreground="#ff57f4ff"/>

  <!-- numeros -->
  <style name="def:number"
         foreground="#b5cea8"/>

  <!-- comentarios -->
  <style name="def:comment"
         foreground="#6a9955"
         italic="true"/>

  <!-- operadores -->
  <style name="def:operator"
         foreground="#f44747"/>

  <!-- statements / logicos -->
  <style name="def:statement"
         foreground="#569cd6"/>

  <!-- simbolos -->
  <style name="def:special-char"
         foreground="#d7ba7d"/>

  <!-- strings -->
  <style name="def:string"
         foreground="#ce9178"/>

</style-scheme>